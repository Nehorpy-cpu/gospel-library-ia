ENV=production
SERVICE_NAME=gospel-library-scraper
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/gospel_library?sslmode=require
REDIS_URL=rediss://default:PASSWORD@HOST:6379

STORAGE_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=gospel-library-assets
STORAGE_REGION=auto
R2_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=gospel-library-assets
R2_REGION=auto

SCRAPER_RATE_LIMIT=8
SCRAPER_USER_AGENT=GospelLibraryIA/1.0 (+https://app.gospel-library-ia.example)
CRAWLER_CONCURRENCY=8
CRAWLER_DOWNLOAD_DELAY_SECONDS=0.35
CRAWLER_TIMEOUT_SECONDS=45
CRAWLER_MAX_DEPTH=4
CRAWLER_RESPECT_ROBOTS_TXT=true
PLAYWRIGHT_ENABLED=true
PLAYWRIGHT_HEADLESS=true
OCR_ENABLED=true
OCR_LANGUAGE=eng+spa+por
PDF_TEXT_DENSITY_THRESHOLD=80
SENTRY_DSN=
