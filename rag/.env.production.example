ENV=production
SERVICE_NAME=gospel-library-rag
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/gospel_library?sslmode=require
REDIS_URL=rediss://default:PASSWORD@HOST:6379

QDRANT_URL=https://CLUSTER-ID.REGION.aws.cloud.qdrant.io
QDRANT_API_KEY=
QDRANT_COLLECTION=doctrinal_chunks_v1

OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=3072
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_RERANK_MODEL=gpt-4.1-mini
AI_COST_MODE=balanced
RAG_TOP_K=12
MAX_DAILY_EMBEDDING_TOKENS=100000
MAX_USER_CHAT_MESSAGES_PER_DAY=50
MAX_USER_TALK_BUILDER_PER_DAY=20
EMBEDDING_TOKEN_PRICE_PER_1K=0.00013

CHUNK_TARGET_TOKENS=650
CHUNK_SIZE=650
CHUNK_MIN_TOKENS=180
CHUNK_MAX_TOKENS=950
CHUNK_OVERLAP_TOKENS=120
CHUNK_OVERLAP=120
EMBEDDING_BATCH_SIZE=64
RETRIEVAL_SEMANTIC_LIMIT=80
RETRIEVAL_BM25_LIMIT=80
RETRIEVAL_FINAL_LIMIT=12
RETRIEVAL_CONTEXT_TOKEN_BUDGET=10000
RETRIEVAL_CANDIDATE_TOKEN_BUDGET=22000
CACHE_TTL_SECONDS=900
MEMORY_MAX_MESSAGES=12
ANSWER_MAX_CONTEXT_CITATIONS=10
SENTRY_DSN=
