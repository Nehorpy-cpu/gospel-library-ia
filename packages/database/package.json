{
  "name": "@gospel-library-ia/database",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "migrate:post": "psql \"$DATABASE_URL\" -f sql/post_migrate/001_search_indexes_and_partitions.sql && psql \"$DATABASE_URL\" -f sql/post_migrate/002_partition_templates.sql",
    "seed:sql": "psql \"$DATABASE_URL\" -f prisma/seed.sql",
    "studio": "prisma studio",
    "validate": "prisma validate"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "prisma": "^6.1.0",
    "typescript": "^5.7.2"
  }
}
