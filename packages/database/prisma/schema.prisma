generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationPlan {
  FREE
  PRO
  TEAM
  ENTERPRISE
}

enum OrganizationRole {
  OWNER
  ADMIN
  EDITOR
  MEMBER
  VIEWER
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
  DELETED
}

enum SourceKind {
  BYU_SPEECHES
  BYU_SPEECHES_ES
  DISCURSO_SUD
  GENERAL_CONFERENCE
  CHURCH_MANUAL
  SCRIPTURE
  JOSEPH_SMITH_PAPERS
  BOOK
  PDF
  AUDIO
  VIDEO
  CUSTOM
}

enum DocumentKind {
  SPEECH
  GENERAL_CONFERENCE_TALK
  MANUAL
  SCRIPTURE_BOOK
  SCRIPTURE_CHAPTER
  SCRIPTURE_BLOCK
  HISTORICAL_DOCUMENT
  BOOK
  PDF
  AUDIO_TRANSCRIPT
  VIDEO_TRANSCRIPT
  NOTE
}

enum DocumentStatus {
  DISCOVERED
  QUEUED
  FETCHING
  DOWNLOADED
  EXTRACTING
  OCR_PENDING
  TRANSCRIBING
  CHUNKING
  EMBEDDING
  INDEXING
  READY
  FAILED
  ARCHIVED
  TAKEDOWN
}

enum Visibility {
  PUBLIC
  PRIVATE
  ORGANIZATION
  UNLISTED
}

enum AssetKind {
  HTML
  PDF
  IMAGE
  AUDIO
  VIDEO
  THUMBNAIL
  TRANSCRIPT
  OCR_TEXT
  EXPORT
}

enum JobStatus {
  QUEUED
  RUNNING
  RETRYING
  COMPLETED
  FAILED
  CANCELLED
}

enum ChatRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum SyncOperation {
  CREATE
  UPDATE
  DELETE
  RESTORE
}

enum SyncEntity {
  NOTE
  HIGHLIGHT
  FAVORITE
  COLLECTION
  COLLECTION_ITEM
  READING_HISTORY
  CHAT_SESSION
  CHAT_MESSAGE
  STUDY_WORKSPACE
  STUDY_NOTE
  STUDY_HIGHLIGHT
  SAVED_CITATION
  POST_IT
  STUDY_WORKSPACE_SOURCE
}

model Organization {
  id           String           @id @default(uuid()) @db.Uuid
  name         String
  slug         String           @unique
  plan         OrganizationPlan @default(FREE)
  locale       String           @default("es") @db.VarChar(16)
  timezone     String           @default("America/Asuncion")
  settings     Json             @default("{}")
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships  Membership[]
  collections  Collection[]
  documents    Document[]
  auditLogs    AuditLog[]
  syncEvents   SyncEvent[]
  apiKeys      ApiKey[]

  @@map("organizations")
}

model User {
  id              String       @id @default(uuid()) @db.Uuid
  email           String       @unique
  passwordHash    String?      @map("password_hash")
  fullName        String?      @map("full_name")
  avatarUrl       String?      @map("avatar_url")
  locale          String       @default("es") @db.VarChar(16)
  status          UserStatus   @default(ACTIVE)
  lastLoginAt     DateTime?    @map("last_login_at") @db.Timestamptz(6)
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships     Membership[]
  sessions        UserSession[]
  favorites       Favorite[]
  readingHistory  ReadingHistory[]
  collections     Collection[]
  notes           Note[]
  highlights      Highlight[]
  chatSessions    ChatSession[]
  exports         ExportJob[]
  auditLogs       AuditLog[]
  syncEvents      SyncEvent[]
  studyWorkspaces StudyWorkspace[]
  studyWorkspaceSources StudyWorkspaceSource[]
  studyNotes      StudyNote[]
  studyHighlights StudyHighlight[]
  savedCitations  SavedCitation[]
  postIts         PostIt[]

  @@index([status])
  @@map("users")
}

model Membership {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  role           OrganizationRole @default(MEMBER)
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId, role])
  @@map("memberships")
}

model UserSession {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  refreshHash  String    @map("refresh_hash")
  userAgent    String?   @map("user_agent")
  ipAddress    String?   @map("ip_address") @db.Inet
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt    DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("user_sessions")
}

model UserPreference {
  userId              String   @id @map("user_id") @db.Uuid
  callingCategory     String?  @map("calling_category") @db.VarChar(120)
  callingName         String?  @map("calling_name") @db.VarChar(200)
  customCallingName   String?  @map("custom_calling_name") @db.VarChar(200)
  callingFocusEnabled Boolean  @default(false) @map("calling_focus_enabled")
  settings            Json     @default("{}")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([callingCategory, callingName])
  @@map("user_preferences")
}

model ApiKey {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  name           String
  keyHash        String       @map("key_hash") @unique
  scopes         String[]     @default([])
  lastUsedAt     DateTime?    @map("last_used_at") @db.Timestamptz(6)
  expiresAt      DateTime?    @map("expires_at") @db.Timestamptz(6)
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("api_keys")
}

model Source {
  id              String       @id @default(uuid()) @db.Uuid
  key             String       @unique @db.VarChar(100)
  name            String
  kind            SourceKind
  baseUrl         String?      @map("base_url")
  sourceType      String?      @map("source_type") @db.VarChar(100)
  language        String?      @db.VarChar(16)
  defaultLanguage String?      @map("default_language") @db.VarChar(16)
  isOfficial      Boolean      @default(false) @map("is_official")
  trustLevel      Int          @default(5) @map("trust_level")
  scrapingEnabled Boolean      @default(true) @map("scraping_enabled")
  enabled         Boolean      @default(true)
  crawlStrategy   String       @default("html_discovery") @map("crawl_strategy") @db.VarChar(80)
  rateLimit       Int          @default(30) @map("rate_limit")
  maxPagesPerRun  Int          @default(25) @map("max_pages_per_run")
  lastCrawledAt   DateTime?    @map("last_crawled_at") @db.Timestamptz(6)
  robotsPolicyNotes String?    @map("robots_policy_notes")
  config          Json         @default("{}")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  documents       Document[]
  crawlUrls       CrawlUrl[]

  @@index([kind])
  @@index([isOfficial, trustLevel])
  @@index([enabled, sourceType])
  @@index([lastCrawledAt])
  @@map("sources")
}

model SourceLegacyCleanupAudit {
  sourceId           String   @id @map("source_id") @db.Uuid
  sourceKey          String   @map("source_key") @db.VarChar(100)
  previousEnabled    Boolean  @map("previous_enabled")
  previousSourceType String?  @map("previous_source_type") @db.VarChar(100)
  previousConfig     Json     @default("{}") @map("previous_config")
  replacementKey     String?  @map("replacement_key") @db.VarChar(100)
  migratedAt         DateTime @default(now()) @map("migrated_at") @db.Timestamptz(6)

  @@map("source_legacy_cleanup_audit")
}

model DocumentMetadataRepairAudit {
  id            String    @id @default(uuid()) @db.Uuid
  documentId    String    @map("document_id") @db.Uuid
  fieldName     String    @map("field_name") @db.VarChar(40)
  previousValue String?   @map("previous_value")
  repairedValue String    @map("repaired_value")
  repairedFrom  String    @map("repaired_from") @db.VarChar(80)
  repairedAt    DateTime  @default(now()) @map("repaired_at") @db.Timestamptz(6)
  revertedAt    DateTime? @map("reverted_at") @db.Timestamptz(6)

  @@unique([documentId, fieldName], map: "uq_document_metadata_repair_field")
  @@index([documentId], map: "idx_document_metadata_repair_audit_document")
  @@map("document_metadata_repair_audit")
}

model Author {
  id            String          @id @default(uuid()) @db.Uuid
  slug          String          @unique
  displayName   String          @map("display_name")
  sortName      String?         @map("sort_name")
  normalizedName String         @map("normalized_name")
  bio           String?
  birthDate     DateTime?       @map("birth_date") @db.Date
  deathDate     DateTime?       @map("death_date") @db.Date
  metadata      Json            @default("{}")
  createdAt     DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  documents     DocumentAuthor[]

  @@index([normalizedName])
  @@map("authors")
}

model Category {
  id           String      @id @default(uuid()) @db.Uuid
  parentId     String?     @map("parent_id") @db.Uuid
  slug         String      @unique
  name         String
  language     String      @default("es") @db.VarChar(16)
  description  String?
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  parent       Category?   @relation("CategoryTree", fields: [parentId], references: [id])
  children     Category[]  @relation("CategoryTree")
  documents    DocumentCategory[]

  @@index([parentId])
  @@index([language])
  @@map("categories")
}

model Tag {
  id             String        @id @default(uuid()) @db.Uuid
  slug           String        @unique
  name           String
  normalizedName String        @map("normalized_name")
  language       String        @default("es") @db.VarChar(16)
  description    String?
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  documents      DocumentTag[]
  chunks         ChunkTag[]

  @@index([normalizedName])
  @@index([language])
  @@map("tags")
}

model ScriptureReference {
  id             String      @id @default(uuid()) @db.Uuid
  work           String      @db.VarChar(80)
  book           String      @db.VarChar(120)
  chapter        Int?
  verseStart     Int?        @map("verse_start")
  verseEnd       Int?        @map("verse_end")
  osisRef        String?     @map("osis_ref")
  displayRef     String      @map("display_ref")
  language       String      @default("es") @db.VarChar(16)
  normalizedRef  String      @map("normalized_ref")
  metadata       Json        @default("{}")
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  documents      DocumentScriptureReference[]
  chunks         ChunkScriptureReference[]

  @@unique([work, book, chapter, verseStart, verseEnd, language])
  @@index([normalizedRef])
  @@index([work, book, chapter])
  @@map("scripture_references")
}

model Document {
  id               String         @id @default(uuid()) @db.Uuid
  organizationId   String?        @map("organization_id") @db.Uuid
  sourceId         String         @map("source_id") @db.Uuid
  canonicalId      String?        @map("canonical_id")
  slug             String?
  title            String
  subtitle         String?
  kind             DocumentKind
  status           DocumentStatus @default(DISCOVERED)
  visibility       Visibility     @default(PUBLIC)
  language         String         @default("es") @db.VarChar(16)
  originalLanguage String?        @map("original_language") @db.VarChar(16)
  canonicalUrl     String?        @map("canonical_url")
  originalUrl      String?        @map("original_url")
  publishedAt      DateTime?      @map("published_at") @db.Date
  sourceUpdatedAt  DateTime?      @map("source_updated_at") @db.Timestamptz(6)
  contentText      String?        @map("content_text")
  contentHash      String?        @map("content_hash") @db.VarChar(64)
  metadata         Json           @default("{}")
  doctrineScore    Int            @default(5) @map("doctrine_score")
  readingMinutes   Int?           @map("reading_minutes")
  wordCount        Int?           @map("word_count")
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt        DateTime?      @map("deleted_at") @db.Timestamptz(6)

  organization     Organization?  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  source           Source         @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  translations     DocumentTranslation[]
  authors          DocumentAuthor[]
  categories       DocumentCategory[]
  tags             DocumentTag[]
  scriptures       DocumentScriptureReference[]
  assets           MediaAsset[]
  chunks           DocumentChunk[]
  favorites        Favorite[]
  readingHistory   ReadingHistory[]
  collectionItems  CollectionItem[]
  notes            Note[]
  highlights       Highlight[]
  chatCitations    ChatCitation[]
  documentVersions DocumentVersion[]
  studyNotes       StudyNote[]
  studyHighlights  StudyHighlight[]
  savedCitations   SavedCitation[]
  postIts          PostIt[]

  @@unique([sourceId, canonicalUrl])
  @@unique([sourceId, canonicalId])
  @@index([organizationId])
  @@index([sourceId, status])
  @@index([kind, language])
  @@index([publishedAt])
  @@index([contentHash])
  @@index([visibility, status])
  @@map("documents")
}

model DocumentVersion {
  id          String   @id @default(uuid()) @db.Uuid
  documentId  String   @map("document_id") @db.Uuid
  version     Int
  contentHash String   @map("content_hash") @db.VarChar(64)
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  document    Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, version])
  @@index([contentHash])
  @@map("document_versions")
}

model DocumentTranslation {
  id             String   @id @default(uuid()) @db.Uuid
  documentId     String   @map("document_id") @db.Uuid
  language       String   @db.VarChar(16)
  title          String
  subtitle       String?
  contentText    String?  @map("content_text")
  translator     String?
  translationUrl String?  @map("translation_url")
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  document       Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, language])
  @@index([language])
  @@map("document_translations")
}

model DocumentAuthor {
  documentId String   @map("document_id") @db.Uuid
  authorId   String   @map("author_id") @db.Uuid
  role       String   @default("author") @db.VarChar(40)
  sortOrder  Int      @default(0) @map("sort_order")

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  author     Author   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@id([documentId, authorId, role])
  @@index([authorId])
  @@map("document_authors")
}

model DocumentCategory {
  documentId String   @map("document_id") @db.Uuid
  categoryId String   @map("category_id") @db.Uuid

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([documentId, categoryId])
  @@index([categoryId])
  @@map("document_categories")
}

model DocumentTag {
  documentId String   @map("document_id") @db.Uuid
  tagId      String   @map("tag_id") @db.Uuid
  confidence Float?   @db.Real

  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([documentId, tagId])
  @@index([tagId])
  @@map("document_tags")
}

model DocumentScriptureReference {
  documentId  String             @map("document_id") @db.Uuid
  referenceId String             @map("reference_id") @db.Uuid
  occurrences Int                @default(1)

  document    Document           @relation(fields: [documentId], references: [id], onDelete: Cascade)
  reference   ScriptureReference @relation(fields: [referenceId], references: [id], onDelete: Cascade)

  @@id([documentId, referenceId])
  @@index([referenceId])
  @@map("document_scripture_references")
}

model DocumentChunk {
  id              String       @id @default(uuid()) @db.Uuid
  documentId      String       @map("document_id") @db.Uuid
  chunkIndex      Int          @map("chunk_index")
  chunkerVersion  String       @default("smart-v1") @map("chunker_version") @db.VarChar(64)
  language        String       @default("es") @db.VarChar(16)
  title           String?
  sectionTitle    String?      @map("section_title")
  pageNumber      Int?         @map("page_number")
  startChar       Int          @map("start_char")
  endChar         Int          @map("end_char")
  tokenCount      Int          @map("token_count")
  text            String
  textHash        String       @map("text_hash") @db.VarChar(64)
  metadata        Json         @default("{}")
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  document        Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  embeddings      Embedding[]
  embeddingCaches EmbeddingCache[]
  tags            ChunkTag[]
  scriptures      ChunkScriptureReference[]
  notes           Note[]
  highlights      Highlight[]
  collectionItems CollectionItem[]
  studyHighlights StudyHighlight[]
  favorites       Favorite[]
  chatCitations   ChatCitation[]

  @@unique([documentId, chunkIndex, chunkerVersion])
  @@index([documentId])
  @@index([language])
  @@index([textHash])
  @@index([documentId, pageNumber])
  @@map("document_chunks")
}

model ChunkTag {
  chunkId    String        @map("chunk_id") @db.Uuid
  tagId      String        @map("tag_id") @db.Uuid
  confidence Float?        @db.Real

  chunk      DocumentChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  tag        Tag           @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([chunkId, tagId])
  @@index([tagId])
  @@map("chunk_tags")
}

model ChunkScriptureReference {
  chunkId     String             @map("chunk_id") @db.Uuid
  referenceId String             @map("reference_id") @db.Uuid
  startChar   Int?               @map("start_char")
  endChar     Int?               @map("end_char")

  chunk       DocumentChunk      @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  reference   ScriptureReference @relation(fields: [referenceId], references: [id], onDelete: Cascade)

  @@id([chunkId, referenceId])
  @@index([referenceId])
  @@map("chunk_scripture_references")
}

model EmbeddingModel {
  id          String      @id @default(uuid()) @db.Uuid
  provider    String      @default("openai") @db.VarChar(80)
  name        String      @db.VarChar(160)
  dimensions  Int
  version     String      @db.VarChar(80)
  isActive    Boolean     @default(true) @map("is_active")
  metadata    Json        @default("{}")
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  embeddings  Embedding[]

  @@unique([provider, name, version, dimensions])
  @@index([isActive])
  @@map("embedding_models")
}

model Embedding {
  id            String         @id @default(uuid()) @db.Uuid
  chunkId       String         @map("chunk_id") @db.Uuid
  modelId       String         @map("model_id") @db.Uuid
  qdrantPointId String         @map("qdrant_point_id") @db.Uuid
  collection    String         @db.VarChar(120)
  contentHash   String         @map("content_hash") @db.VarChar(64)
  payload       Json           @default("{}")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  chunk         DocumentChunk  @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  model         EmbeddingModel @relation(fields: [modelId], references: [id], onDelete: Restrict)

  @@unique([chunkId, modelId, contentHash])
  @@unique([collection, qdrantPointId])
  @@index([modelId])
  @@index([contentHash])
  @@map("embeddings")
}

model EmbeddingCache {
  id          String    @id @default(uuid()) @db.Uuid
  contentHash String    @map("content_hash") @db.VarChar(64)
  model       String    @db.VarChar(128)
  dimensions  Int
  vector      Json?
  vectorId    String?   @map("vector_id") @db.Uuid
  chunkId     String?   @map("chunk_id") @db.Uuid
  tokenCount  Int       @default(0) @map("token_count")
  hitCount    Int       @default(0) @map("hit_count")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz(6)

  chunk       DocumentChunk? @relation(fields: [chunkId], references: [id], onDelete: SetNull)

  @@unique([contentHash, model])
  @@index([model])
  @@index([chunkId])
  @@map("embedding_cache")
}

model AiUsageEvent {
  id               String    @id @default(uuid()) @db.Uuid
  kind             String    @db.VarChar(64)
  model            String?   @db.VarChar(128)
  userId           String?   @map("user_id") @db.Uuid
  workspaceId      String?   @map("workspace_id") @db.Uuid
  documentId       String?   @map("document_id") @db.Uuid
  chunkId          String?   @map("chunk_id") @db.Uuid
  inputTokens      Int       @default(0) @map("input_tokens")
  outputTokens     Int       @default(0) @map("output_tokens")
  estimatedCostUsd Float     @default(0) @map("estimated_cost_usd")
  status           String    @default("ok") @db.VarChar(64)
  errorCode        String?   @map("error_code") @db.VarChar(128)
  metadata         Json      @default("{}")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([createdAt])
  @@index([kind])
  @@index([userId, createdAt])
  @@map("ai_usage_events")
}

model AiRuntimeState {
  key       String   @id @db.VarChar(120)
  value     Json     @default("{}")
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("ai_runtime_state")
}

model BetaAccess {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String?   @map("user_id") @db.Uuid
  email                 String    @unique(map: "uq_beta_access_email") @db.VarChar(320)
  name                  String?
  status                String    @default("pending") @db.VarChar(32)
  studyProfile          String?   @map("study_profile") @db.VarChar(160)
  preferredLanguage     String?   @map("preferred_language") @db.VarChar(16)
  preferredSources      Json      @default("[]") @map("preferred_sources")
  requestMessage        String?   @map("request_message")
  adminNotes            String?   @map("admin_notes")
  approvedAt            DateTime? @map("approved_at") @db.Timestamptz(6)
