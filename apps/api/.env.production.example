ENV=production
LOG_LEVEL=INFO

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/gospel_library?sslmode=require
REDIS_URL=rediss://default:PASSWORD@HOST:6379

QDRANT_URL=https://CLUSTER-ID.REGION.aws.cloud.qdrant.io
QDRANT_API_KEY=
QDRANT_COLLECTION=doctrinal_chunks_v1
QDRANT_DIMENSIONS=3072

OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=3072
OPENAI_CHAT_MODEL=gpt-5.5

RAG_API_URL=https://rag.gospel-library-ia.example
SCRAPER_API_URL=https://scraper.gospel-library-ia.example
CORS_ORIGINS=http://localhost:3000,https://www.estudiopy.com,https://estudiopy.com
RATE_LIMIT_PER_MINUTE=120
CHAT_RATE_LIMIT_PER_MINUTE=30
MAX_USER_STUDY_AI_PER_DAY=20
STUDY_AI_MAX_SUGGESTIONS=10

STORAGE_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=gospel-library-assets
STORAGE_REGION=auto
R2_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=gospel-library-assets
R2_REGION=auto

AUTH_PROVIDER=clerk
ALLOW_DEV_AUTH_HEADERS=false
ALLOW_STUDY_DEMO_USER=true
STUDY_DEMO_USER_ID=00000000-0000-4000-8000-000000000001
CLERK_SECRET_KEY=
CLERK_JWKS_URL=
CLERK_JWT_ISSUER=
CLERK_WEBHOOK_SECRET=
CLERK_ADMIN_EMAILS=
ADMIN_USER_IDS=
INGESTION_API_KEY=
SENTRY_DSN=
