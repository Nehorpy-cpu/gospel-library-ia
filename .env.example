ENV=local
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://gospel:gospel@postgres:5432/gospel_library
REDIS_URL=redis://redis:6379/0

R2_ENDPOINT_URL=http://minio:9000
R2_ACCESS_KEY_ID=minio
R2_SECRET_ACCESS_KEY=miniosecret
R2_BUCKET=gospel-library-assets
R2_REGION=auto

CRAWLER_CONCURRENCY=8
CRAWLER_DOWNLOAD_DELAY_SECONDS=0.35
CRAWLER_TIMEOUT_SECONDS=45
CRAWLER_MAX_DEPTH=4
CRAWLER_RESPECT_ROBOTS_TXT=true

PLAYWRIGHT_ENABLED=true
PLAYWRIGHT_HEADLESS=true
OCR_ENABLED=true
OCR_LANGUAGE=eng+spa+por
PDF_TEXT_DENSITY_THRESHOLD=80

OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=3072
OPENAI_CHAT_MODEL=gpt-5.5
OPENAI_RERANK_MODEL=gpt-4.1-mini
AI_COST_MODE=balanced
RAG_TOP_K=12
MAX_DAILY_EMBEDDING_TOKENS=100000
MAX_USER_CHAT_MESSAGES_PER_DAY=50
MAX_USER_TALK_BUILDER_PER_DAY=20
MAX_USER_EXPORTS_PER_DAY=10
MAX_USER_STUDY_AI_PER_DAY=20
STUDY_AI_MAX_SUGGESTIONS=10
BETA_MAX_WORKSPACES_PER_USER=12
BETA_ALLOWLIST_ENABLED=false
BETA_ENVIRONMENT=beta
BETA_VERSION=0.1.0-beta
EMBEDDING_TOKEN_PRICE_PER_1K=0.00013

QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=doctrinal_chunks_v1

CHUNK_TARGET_TOKENS=650
CHUNK_SIZE=650
CHUNK_MIN_TOKENS=180
CHUNK_MAX_TOKENS=950
CHUNK_OVERLAP_TOKENS=120
CHUNK_OVERLAP=120
EMBEDDING_BATCH_SIZE=64
RETRIEVAL_SEMANTIC_LIMIT=80
RETRIEVAL_BM25_LIMIT=80
RETRIEVAL_FINAL_LIMIT=12
RETRIEVAL_CONTEXT_TOKEN_BUDGET=10000
RETRIEVAL_CANDIDATE_TOKEN_BUDGET=22000
CACHE_TTL_SECONDS=900
MEMORY_MAX_MESSAGES=12

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_ENVIRONMENT=development
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
RAG_API_URL=http://rag-api:8090
SCRAPER_API_URL=http://scraper-api:8080
CORS_ORIGINS=http://localhost:3000,http://web:3000
RATE_LIMIT_PER_MINUTE=120
CHAT_RATE_LIMIT_PER_MINUTE=30
QDRANT_DIMENSIONS=3072

AUTH_PROVIDER=clerk
ALLOW_DEV_AUTH_HEADERS=true
CLERK_SECRET_KEY=
CLERK_JWKS_URL=
CLERK_JWT_ISSUER=
CLERK_WEBHOOK_SECRET=
CLERK_ADMIN_EMAILS=
ADMIN_USER_IDS=

POSTGRES_BACKUP_KEEP_DAYS=7
POSTGRES_BACKUP_KEEP_WEEKS=4
POSTGRES_BACKUP_KEEP_MONTHS=6
