ENV=production
LOG_LEVEL=INFO

DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/gospel_library?sslmode=require
REDIS_URL=rediss://default:PASSWORD@HOST:6379

QDRANT_URL=https://CLUSTER-ID.REGION.aws.cloud.qdrant.io
QDRANT_API_KEY=
QDRANT_COLLECTION=doctrinal_chunks_v1

OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=3072
OPENAI_CHAT_MODEL=gpt-5.5

STORAGE_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET=gospel-library-assets
STORAGE_REGION=auto
R2_ENDPOINT_URL=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=gospel-library-assets
R2_REGION=auto

SCRAPER_RATE_LIMIT=8
SCRAPER_USER_AGENT=GospelLibraryIA/1.0 (+https://app.gospel-library-ia.example)
CRAWLER_CONCURRENCY=8
PLAYWRIGHT_ENABLED=true
OCR_ENABLED=true
SENTRY_DSN=
